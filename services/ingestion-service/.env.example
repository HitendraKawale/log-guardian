# Ingestion service configuration (copy to .env for local overrides)
AI_SERVICE_URL=http://localhost:8001
AI_TIMEOUT=2
DATABASE_URL=sqlite+aiosqlite:///./log_guardian.db

# Security (optional). Set API_KEY to require an X-API-Key header on /logs.
# CORS_ALLOW_ORIGINS can be a comma-separated allowlist instead of "*".
API_KEY=
CORS_ALLOW_ORIGINS=*
RATE_LIMIT_PER_MINUTE=0
